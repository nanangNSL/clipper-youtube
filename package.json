{
  "name": "yt-tiktok-clipper",
  "version": "1.0.0",
  "description": "Web tool to clip YouTube videos into vertical TikTok format with hook title & footer overlays.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "update-ytdlp": "node -e \"require('child_process').execFileSync(require('youtube-dl-exec').constants.YOUTUBE_DL_PATH, ['-U'], { stdio: 'inherit' })\""
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "multer": "^2.0.1",
    "sharp": "^0.33.4",
    "uuid": "^9.0.1",
    "youtube-dl-exec": "^3.0.10"
  }
}
